#include <iostream>
using namespace std;

int main()
{
    int n, i, j, min, temp;

    cout << "Enter number of elements: ";
    cin >> n;

    int a[n];

    cout << "Enter elements:\n";
    for(i = 0; i < n; i++)
    {
        cin >> a[i];
    }

    // Selection Sort
    for(i = 0; i < n - 1; i++)
    {
        min = i;
        for(j = i + 1; j < n; j++)
        {
            if(a[j] < a[min])
            {
                min = j;
            }
        }

        // Swap
        temp = a[i];
        a[i] = a[min];
        a[min] = temp;
    }

    cout << "Sorted array:\n";
    for(i = 0; i < n; i++)
    {
        cout << a[i] << " ";
    }

    return 0;
}

#include <iostream>
using namespace std;

int main()
{
    int n, i, sum = 0;

    cout << "Enter number of elements: ";
    cin >> n;

    // Dynamic memory allocation
    int *a = new int[n];

    cout << "Enter elements:\n";
    for(i = 0; i < n; i++)
    {
        cin >> a[i];
        sum = sum + a[i];
    }

    cout << "Sum of elements = " << sum;

    // Free allocated memory
    delete[] a;

    return 0;
}

#include <iostream>
using namespace std;

// Call by Value
void swapValue(int a, int b)
{
    int temp;
    temp = a;
    a = b;
    b = temp;

    cout << "Inside swapValue function: a = " << a << " b = " << b << endl;
}

// Call by Reference
void swapReference(int &a, int &b)
{
    int temp;
    temp = a;
    a = b;
    b = temp;
}

int main()
{
    int x = 10, y = 20;

    cout << "Before swapping: x = " << x << " y = " << y << endl;

    // Call by Value
    swapValue(x, y);
    cout << "After swapValue (Call by Value): x = " << x << " y = " << y << endl;

    // Call by Reference
    swapReference(x, y);
    cout << "After swapReference (Call by Reference): x = " << x << " y = " << y << endl;

    return 0;
}

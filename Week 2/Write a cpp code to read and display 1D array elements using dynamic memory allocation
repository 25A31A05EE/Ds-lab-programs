#include <iostream>
using namespace std;

int main()
{
    int n;

    cout << "Enter number of elements: ";
    cin >> n;

    int *arr;

    // Dynamic memory allocation
    arr = new int[n];

    cout << "Enter the elements:\n";
    for(int i = 0; i < n; i++)
    {
        cin >> arr[i];
    }

    cout << "Array elements are:\n";
    for(int i = 0; i < n; i++)
    {
        cout << arr[i] << " ";
    }

    // Free allocated memory
    delete[] arr;

    return 0;
}
